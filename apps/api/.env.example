# st-api configuration (all optional; sane dev defaults apply). Prefix: ST_
# Copy to .env for local dev. NEVER commit a real .env.

# CORS: pin to your published extension id(s) in prod (comma-separated). Unset (dev) ->
# any well-formed unpacked-extension origin is accepted (never a blanket wildcard).
# ST_ALLOWED_EXTENSION_IDS=abcdefghijklmnopabcdefghijklmnop
# ST_REDIS_URL=redis://localhost:6379/0        # unset -> in-memory cache (dev only)
# ST_LLM_API_KEY=sk-...                         # unset -> `full` mode degrades to heuristics-only
# ST_LLM_MODEL=claude-opus-4-8
# ST_CACHE_TTL_SECONDS=604800                   # 7 days
# ST_FETCH_TIMEOUT_SECONDS=3.0
# ST_FETCH_MAX_REDIRECTS=3
